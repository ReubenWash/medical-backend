SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────────────────────────
# For local dev: leave blank to use SQLite fallback, or set a postgres URL
# DATABASE_URL=postgres://user:pass@localhost:5432/medicare

# ── Email (Gmail example) ─────────────────────────────────────────────────────
# In production on Render, set these env vars in the dashboard:
#
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=yourgmail@gmail.com
#   EMAIL_HOST_PASSWORD=your-gmail-app-password   <-- NOT your real password
#   DEFAULT_FROM_EMAIL=MediCare Clinic <yourgmail@gmail.com>
#
# In development, emails print to the terminal (console backend by default).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Frontend URL (used in email links) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Cloudinary (persistent image storage for Render) ──────────────────────────
# Sign up free at https://cloudinary.com, then copy your CLOUDINARY_URL from
# the dashboard. Add it to Render env vars. Leave blank for local dev.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
